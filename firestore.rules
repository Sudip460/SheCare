rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isDoctor() {
      return signedIn()
        && ownUserDoc().data.profile.role == "doctor";
    }

    function doctorId() {
      return ownUserDoc().data.profile.doctorId != null
        ? ownUserDoc().data.profile.doctorId
        : request.auth.uid;
    }

    function isLinkedDoctor(userId) {
      return isDoctor()
        && get(/databases/$(database)/documents/users/$(userId)).data.profile.role == "patient"
        && get(/databases/$(database)/documents/users/$(userId)).data.profile.doctorId == doctorId();
    }

    function isAcceptedAssignedDoctor(userId) {
      return isLinkedDoctor(userId)
        && get(/databases/$(database)/documents/users/$(userId)).data.profile.doctorStatus == "accepted";
    }

    function validDoctorDecision(userId) {
      return isLinkedDoctor(userId)
        && resource.data.profile.doctorStatus == "pending"
        && request.resource.data.profile.doctorStatus in ["accepted", "rejected"]
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["profile"])
        && request.resource.data.profile.diff(resource.data.profile).affectedKeys().hasOnly(["doctorStatus", "doctorDecisionAt"]);
    }

    match /doctors/{doctorId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if signedIn()
        && (request.auth.uid == userId
          || (isDoctor()
            && resource.data.profile.role == "patient"
            && resource.data.profile.doctorId == doctorId()));
      allow create, delete: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (request.auth.uid == userId || validDoctorDecision(userId));

      match /sessions/{sessionId} {
        allow read: if signedIn() && (request.auth.uid == userId || isAcceptedAssignedDoctor(userId));
        allow write: if signedIn() && request.auth.uid == userId;
      }

      match /reports/{reportId} {
        allow read: if signedIn() && (request.auth.uid == userId || isAcceptedAssignedDoctor(userId));
        allow write: if signedIn() && request.auth.uid == userId;
      }
    }
  }
}
